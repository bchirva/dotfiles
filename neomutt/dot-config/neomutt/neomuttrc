#~~~ Common settings ~~~#

set charset = "utf-8"
set editor = "nvim"

set smtp_authenticators = 'gssapi:login'
set sleep_time = 0
set markers = no
set mark_old = no
set mime_forward = no
set forward_attachments = yes
set wait_key = no

set imap_check_subscribed = yes
set mail_check_stats = yes

#~~~ Index settings ~~~#

set sort = "reverse-date"
set flag_chars="ó°“¹ï€…ï‡¸ó±«ƒó°‘šïƒ ïƒ ïƒ ïƒ "
set to_chars=" ï“¿ïƒ€ïƒ€ó±ƒœï‡ªï„’"
set crypt_chars="î¯©ï€£î¹¿ï‚„ "

set date_format="%d.%m.%Y %H:%M"
set index_format="%Z %{%d.%m.%Y} %-20.20F %s"

#~~~ Sidebar settings ~~~#

set sidebar_format = "%D %* [%?N?%N / ?%S]"
set sidebar_indent_string = " "
set sidebar_visible = yes
set sidebar_folder_indent
set sidebar_width = 30
set sidebar_short_path = yes
set sidebar_next_new_wrap = yes

#~~~ Pager settings ~~~#

set mailcap_path = "$XDG_CONFIG_HOME/neomutt/mailcap"
auto_view text/html
alternative_order text/plain text/html

ignore *
unignore From To Cc Date Subject

#~~~ Keybindings ~~~#

bind index,pager,browser g noop

bind index,pager \Ck sidebar-prev
bind index,pager \Cj sidebar-next
bind index,pager \Co sidebar-open
bind index,pager \Cp sidebar-prev-new
bind index,pager \Cn sidebar-next-new
bind index,pager \Cb sidebar-toggle-visible

bind index j next-entry
bind index k previous-entry
bind index l display-message
bind index gg first-entry
bind index G last-entry
bind index D delete-message
bind index U undelete-message
bind index o display-message

bind pager j next-line
bind pager k previous-line
bind pager h exit
bind pager gg top
bind pager G bottom
bind pager J next-entry
bind pager K previous-entry

bind browser j next-entry
bind browser k previous-entry
bind browser l select-entry
bind browser h exit
bind browser gg first-entry
bind browser G last-entry

bind attach <return> view-mailcap
bind attach o view-mailcap
bind attach l view-mailcap

# macro index,pager gl "<pipe-message> urlscan<Enter>" "Extract URLs out of message with urlscan"
# macro attach,compose gl "<pipe-entry> urlscan<Enter>" "Extract URLs out of message with urlscan"

#~~~ Accounts ~~~#

source $XDG_CONFIG_HOME/neomutt-accounts/config.rc

#~~~ Colors ~~~#

set color_directcolor = yes
source colors.rc

